---
interface Props {
  label: string
  href?: string
  variant?: 'black' | 'blue' | 'red' | 'white'
  class?: string
}

const {
  label,
  href = '/',
  variant = 'black',
  class: className,
} = Astro.props

const variants = {
  black: 'bg-btn-black-default hover:bg-btn-black-hover text-text-primary',
  blue:  'bg-btn-blue-default  hover:bg-btn-blue-hover  text-text-primary',
  red:   'bg-btn-red-default   hover:bg-btn-red-hover   text-text-primary',
  white: 'bg-btn-white-default hover:bg-btn-white-hover text-text-alternative',
}
---
<a
  href={href}
  class:list={[
    'inline-flex items-center gap-6 pl-4 pr-2 py-2 rounded-[2px]',
    'text-small-caps no-underline transition-colors',
    variants[variant],
    className,
  ]}
>
  <span>{label}</span>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>
