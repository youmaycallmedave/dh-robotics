---
import Layout from '../../layouts/Layout.astro'
import Section from '../../components/ui/Section.astro'
---
<Layout title="News Template">
  <Section>
    <h1>News — Template</h1>
    <ul>
      <li>1. Кнопка "Back to News" → /news</li>
      <li>2. Заголовок статьи, категория (News / Insights), дата</li>
      <li>3. Шеринг — кнопки соцсетей + кнопка скопировать ссылку</li>
      <li>4. Главное изображение</li>
      <li>5. Rich Text — заголовки, текст, видео, цитаты, нумерованные и маркированные списки</li>
      <li>6. Subscribe блок — тот же компонент что на /news index</li>
      <li>7. Other Articles — слайдер карточек других статей + кнопка → /news</li>
    </ul>
  </Section>
</Layout>
